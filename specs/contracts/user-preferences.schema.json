{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zomato-reco.local/schemas/user-preferences.schema.json",
  "title": "UserPreferences",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location",
    "budget",
    "cuisines",
    "min_rating"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "budget": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "cuisines": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50
      }
    },
    "min_rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "additional_preferences": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 100
      },
      "default": []
    },
    "max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    }
  }
}

