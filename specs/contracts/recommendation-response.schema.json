{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zomato-reco.local/schemas/recommendation-response.schema.json",
  "title": "RecommendationResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query_summary",
    "recommendations"
  ],
  "properties": {
    "query_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "restaurant_name",
          "location",
          "cuisine",
          "rating",
          "estimated_cost",
          "explanation"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "restaurant_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "cuisine": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "rating": {
            "type": "number",
            "minimum": 0,
            "maximum": 5
          },
          "estimated_cost": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "explanation": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500
          },
          "match_tags": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "type": "string",
              "minLength": 2,
              "maxLength": 40
            },
            "default": []
          }
        }
      }
    },
    "fallback_used": {
      "type": "boolean",
      "default": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 200
      },
      "default": []
    }
  }
}

